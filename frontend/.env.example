# HX-HouTiKu Frontend Environment Variables
# Copy this file to .env.local and fill in your values.

# API Base URL — the Cloudflare Worker backend URL.
# Leave empty to use the same origin (useful for proxy setup).
# Examples:
#   VITE_API_BASE=https://your-worker.your-domain.workers.dev
#   VITE_API_BASE=http://localhost:8787
VITE_API_BASE=
